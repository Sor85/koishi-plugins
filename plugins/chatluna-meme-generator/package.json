{
  "name": "koishi-plugin-chatluna-meme-generator",
  "version": "0.0.17",
  "description": "为 chatluna-character 提供 meme-generator（python）能力，支持 XML 工具调用、随机模板、自动补全策略",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "koishi",
    "meme",
    "chatluna"
  ],
  "homepage": "https://github.com/Sor85/koishi-plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sor85/koishi-plugins.git"
  },
  "dependencies": {},
  "peerDependencies": {
    "koishi": "^4.18.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "chatluna-xml-tools": "workspace:*",
    "koishi": "^4.18.7",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "koishi": {
    "service": {
      "required": [
        "http"
      ],
      "optional": [
        "notifier",
        "puppeteer",
        "chatluna_character"
      ]
    }
  }
}
