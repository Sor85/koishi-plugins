{
  "name": "koishi-plugin-chatluna-toolbox",
  "description": "为 ChatLuna 提供更多原生工具、XML 工具与变量，仅支持 onebot 平台。",
  "version": "0.0.13",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "dist",
    "client"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Sor85/koishi-plugins",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sor85/koishi-plugins.git"
  },
  "scripts": {
    "build": "tsup && vite build",
    "watch": "tsup --watch",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "chatluna"
  ],
  "peerDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-chatluna": "*",
    "koishi-plugin-chatluna-character": "*",
    "@koishijs/plugin-console": "^5.30.0"
  },
  "peerDependenciesMeta": {
    "koishi-plugin-chatluna-character": {
      "optional": true
    },
    "@koishijs/plugin-console": {
      "optional": true
    }
  },
  "dependencies": {
    "@langchain/core": "^0.3.62",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@koishijs/client": "^5.30.0",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "shared-chatluna-xmltools": "workspace:*",
    "sass": "^1.77.0",
    "shared-nav": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
